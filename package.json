{
	"name": "stoneskills",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
		"preview": "vite preview",
		"check": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
		"lint": "oxlint src vite.config.ts vitest.config.ts --config .oxlintrc.json --react-plugin --vitest-plugin --deny-warnings",
		"format": "oxfmt --config .oxfmtrc.json --write src openspec README.md components.json package.json tsconfig.json tsconfig.app.json tsconfig.node.json vite.config.ts vitest.config.ts .oxlintrc.json .oxfmtrc.json",
		"format:check": "oxfmt --config .oxfmtrc.json --check src openspec README.md components.json package.json tsconfig.json tsconfig.app.json tsconfig.node.json vite.config.ts vitest.config.ts .oxlintrc.json .oxfmtrc.json",
		"test": "vitest",
		"test:run": "vitest run",
		"coverage": "vitest run --coverage",
		"tauri": "tauri",
		"tauri:dev": "tauri dev",
		"tauri:build": "tauri build"
	},
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"@tauri-apps/api": "^2.10.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.7.0",
		"motion": "^12.38.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/cli": "^2.10.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.2",
		"jsdom": "^29.0.1",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.57.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"packageManager": "bun@1.3.11"
}
