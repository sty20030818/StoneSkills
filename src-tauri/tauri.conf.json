{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoneSkills",
  "version": "0.1.0",
  "identifier": "com.stonefish.stoneskills",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StoneSkills",
        "label": "main",
        "width": 1360,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 800,
        "resizable": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
